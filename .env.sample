# Copy this file to .env and fill in your OpenRouter key.
# Get a key at https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-v1-...

# Model IDs as exposed by OpenRouter. Override here if these slugs change.
MODEL_CLAUDE=anthropic/claude-opus-4.7
MODEL_GEMINI=google/gemini-pro-latest
MODEL_GPT=openai/gpt-chat-latest

# Per the paper: temperature fixed at 0.7 for the main run,
# with a sensitivity pilot at 0.3 / 1.0 on the Switch scenario.
TEMPERATURE=0.7

# Optional headers OpenRouter uses for analytics. Safe to leave blank.
OPENROUTER_HTTP_REFERER=https://github.com/your-handle/persona-trolley
OPENROUTER_X_TITLE=Persona-Conditioned Trolley Debate
